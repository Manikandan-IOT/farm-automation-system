# Copy this to .env and fill in your values
# NEVER commit .env to git

# Server
PORT=3000
NODE_ENV=production

# JWT Secret - change this to a long random string
JWT_SECRET=change_this_to_a_very_long_random_secret_string_minimum_32_chars

# JWT expiry
JWT_EXPIRES_IN=7d

# MQTT Broker (your Oracle VM)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=farmuser
MQTT_PASSWORD=your_mqtt_password

# Admin account (created on first run)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeThisPassword123!

# Database path
DB_PATH=./farm_automation.db
